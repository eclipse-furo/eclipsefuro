{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "furo.fat.Any",
  "type": "object",
  "description": "Furo annotated type wrapper message for `any`.\n // Any contains an arbitrary serialized protocol buffer message along with a\n // URL that describes the type of the serialized message. https://github.com/protocolbuffers/protobuf/blob/master/src/google/protobuf/any.protoAny",
  "properties": {
    "attributes": {
      "type": "object",
      "description": "Attributes for a value, something like confidential-msg: you are not allowed to see this value",
      "additionalProperties": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object",
      "description": "Labels / flags for the value, something like unspecified, empty, confidential, absent,... Can be used for AI, UI, Business Logic,...",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "value": {
      "type": "string",
      "description": "The JSON representation for `AnyValue` is a JSON string? The client uses type `ArrayBuffer` for the value field."
    }
  }
}