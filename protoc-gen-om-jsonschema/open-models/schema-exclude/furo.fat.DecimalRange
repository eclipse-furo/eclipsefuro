{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "furo.fat.DecimalRange",
  "type": "object",
  "description": "Represents a decimal range, encoded as a decimal start (inclusive) and a\n  decimal end (exclusive).\n\n  The start must be less than or equal to the end.\n  If a decimal is empty it means min for start and max for end.DecimalRange",
  "properties": {
    "end": {
      "$ref": "furo.type.Decimal",
      "description": "Optional. Exclusive end of the decimal range."
    },
    "start": {
      "$ref": "furo.type.Decimal",
      "description": "Optional. Inclusive start of the decimal range."
    }
  }
}