{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openapi.v3.Info",
  "type": "object",
  "description": "The object provides metadata about the API. The metadata MAY be used by the clients if needed, and MAY be presented in editing or documentation generation tools for convenience.Info",
  "properties": {
    "contact": {
      "$ref": "openapi.v3.Contact"
    },
    "description": {
      "type": "string"
    },
    "license": {
      "$ref": "openapi.v3.License"
    },
    "specificationExtension": {
      "type": "array",
      "items": {
        "$ref": "openapi.v3.NamedAny"
      }
    },
    "summary": {
      "type": "string"
    },
    "termsOfService": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}