{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "google.protobuf.Edition",
  "type": "string",
  "description": "The full set of known editions.",
  "enum": [
    "EDITION_UNKNOWN",
    "EDITION_PROTO2",
    "EDITION_PROTO3",
    "EDITION_2023",
    "EDITION_1_TEST_ONLY",
    "EDITION_2_TEST_ONLY",
    "EDITION_99997_TEST_ONLY",
    "EDITION_99998_TEST_ONLY",
    "EDITION_99999_TEST_ONLY"
  ]
}