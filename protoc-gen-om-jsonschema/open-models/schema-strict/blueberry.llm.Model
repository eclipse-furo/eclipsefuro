{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueberry.llm.Model",
  "type": "object",
  "description": "Model describes an LLM model available on the server.Model",
  "properties": {
    "created": {
      "type": "integer",
      "description": "The Unix timestamp (in seconds) when the model was created."
    },
    "details": {
      "$ref": "blueberry.llm.Model.Details",
      "description": "Ollama-specific model details."
    },
    "digest": {
      "type": "string",
      "description": "SHA-256 digest of the model files."
    },
    "name": {
      "type": "string",
      "description": "Full model name (e.g. \"llama2\")."
    },
    "object": {
      "type": "string",
      "description": "The object type, which is always \"model\"."
    },
    "size": {
      "type": "integer",
      "description": "Size on disk in bytes."
    }
  }
}