{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openapi.v3.NamedString",
  "type": "object",
  "description": "Automatically-generated message used to represent maps of string as ordered (name,value) pairs.NamedString",
  "properties": {
    "name": {
      "type": "string",
      "description": "Map key"
    },
    "value": {
      "type": "string",
      "description": "Mapped value"
    }
  }
}