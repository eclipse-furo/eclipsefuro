{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "google.protobuf.Int32Value",
  "type": "object",
  "description": "Wrapper message for `int32`.\n\n The JSON representation for `Int32Value` is JSON number.Int32Value",
  "properties": {
    "value": {
      "type": "integer",
      "description": "The int32 value."
    }
  }
}