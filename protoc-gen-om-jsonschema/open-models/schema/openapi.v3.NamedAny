{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openapi.v3.NamedAny",
  "type": "object",
  "description": "Automatically-generated message used to represent maps of Any as ordered (name,value) pairs.NamedAny",
  "properties": {
    "name": {
      "type": "string",
      "description": "Map key"
    },
    "value": {
      "$ref": "openapi.v3.Any",
      "description": "Mapped value"
    }
  }
}