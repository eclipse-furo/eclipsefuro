{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueberry.profile.Profile",
  "type": "object",
  "description": "Profile.Profile",
  "properties": {
    "displayName": {
      "type": "string",
      "description": "Calculated by first_name + last_name"
    },
    "email": {
      "type": "string",
      "description": "Current email address"
    },
    "firstName": {
      "type": "string",
      "description": "The first name of the Profile."
    },
    "groups": {
      "type": "array",
      "description": "Group memberships.",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string",
      "description": "The profile id."
    },
    "language": {
      "type": "string",
      "description": "Language like fr-CH  from parameters https://datatracker.ietf.org/doc/html/rfc7231#section-5.3.5"
    },
    "lastName": {
      "type": "string",
      "description": "The Profile’s last name."
    },
    "theme": {
      "type": "string",
      "description": "Theme like  sap_fiori_3,  sap_fiori_3_dark"
    },
    "username": {
      "type": "string",
      "description": "The username or email, or something to identify."
    }
  }
}