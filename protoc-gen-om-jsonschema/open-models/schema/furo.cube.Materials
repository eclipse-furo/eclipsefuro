{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "furo.cube.Materials",
  "type": "string",
  "description": "Types of materials",
  "enum": [
    "MATERIALS_UNSPECIFIED",
    "MATERIALS_GLASS",
    "MATERIALS_WOOD",
    "MATERIALS_CERAMICS",
    "MATERIALS_METALS",
    "MATERIALS_PLASTICS",
    "MATERIALS_TEXTILES",
    "MATERIALS_LEATHER",
    "MATERIALS_PAPER",
    "MATERIALS_RUBBER"
  ]
}